rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // User Profile Validation
    function isValidUserProfile(data) {
      return data.keys().hasAll(['userId', 'fullName', 'email', 'createdAt', 'updatedAt']) &&
             data.keys().size() == 5 &&
             data.userId == request.auth.uid &&
             data.fullName is string && data.fullName.size() > 0 && data.fullName.size() <= 100 &&
             data.email is string && data.email.size() <= 200 &&
             data.createdAt == request.time &&
             data.updatedAt == request.time;
    }

    function isValidUserProfileUpdate(data) {
       return data.keys().hasAll(['userId', 'fullName', 'email', 'createdAt', 'updatedAt']) &&
              data.keys().size() == 5 &&
              data.userId == existing().userId &&
              data.email == existing().email &&
              data.createdAt == existing().createdAt &&
              data.updatedAt == request.time &&
              data.fullName is string && data.fullName.size() > 0 && data.fullName.size() <= 100;
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidId(userId) && isValidUserProfile(incoming());
      allow update: if isOwner(userId) && isValidUserProfileUpdate(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['fullName', 'updatedAt']);
      allow delete: if false; // Profiles are rarely deleted via client
    }
  }
}
